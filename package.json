{
  "name": "exceltable-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@angular/compiler": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.27.2",
    "jsdom": "^29.1.1",
    "ng-packagr": "^21.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rxjs": "^7.8.2",
    "tslib": "^2.6.0",
    "typescript": "^5.9.3",
    "zone.js": "~0.16.0"
  },
  "scripts": {
    "build": "npm run build:core && npm run build:react && npm run build:angular",
    "build:core": "npm run build -w @exceltable/core",
    "build:react": "npm run build -w @exceltable/react",
    "build:angular": "npm run build -w @exceltable/angular",
    "test": "node tests/run.mjs",
    "e2e": "playwright test",
    "e2e:update": "playwright test --update-snapshots"
  }
}
